# ============================================================
# Çocuk Video Filtresi - Örnek Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env adıyla kaydedin ve gerçek
# değerleri doldurun. .env dosyasını asla git'e eklemeyin!
# ============================================================

# PostgreSQL bağlantı URL'i (Prisma ORM tarafından kullanılır)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?connect_timeout=15

# AbacusAI API anahtarı (LLM içerik analizi için - gpt-4.1-mini modeli)
ABACUSAI_API_KEY=

# YouTube Data API v3 anahtarı (video arama ve bilgi çekme için)
YOUTUBE_API_KEY=

# Ebeveyn oturum JWT imzalama anahtarı
# Üretimde güçlü, rastgele bir değer kullanın:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PARENT_JWT_SECRET=

# NextAuth oturum yönetimi için base URL (production'da domain adresiniz olmalı)
NEXTAUTH_URL=https://your-domain.vercel.app

# NextAuth imzalama sırrı (next-auth için gerekli)
# Şu komutla üretin: openssl rand -base64 32
NEXTAUTH_SECRET=

# Build ayarları (opsiyonel)
# NEXT_DIST_DIR=.next
# NEXT_OUTPUT_MODE=standalone
